# Display name for this CA
CA_NAME=Home LAN CA

# Comma-separated hostnames/IPs step-ca should include in its own TLS cert.
# Use the Pi's LAN IP or hostname so other devices on the LAN can reach it.
CA_DNS_NAMES=step-ca,192.168.x.x

# Domain name Traefik uses to request a TLS certificate from step-ca.
# Must resolve to this machine's IP from the LAN (and from inside Docker).
PKI_DOMAIN=pki.lan

# Email for ACME registration with step-ca.
ADMIN_EMAIL=admin@example.com
